    </div>


<!-- ABOUT -->

<section class="about-service">

    <div class="container">

        <h2 class="section-title">

            Content That Builds Brands, Not Just Posts

        </h2>

        <p class="section-text">

            In today’s digital world, content is your brand identity.  
            We create impactful content strategies including blogs, social media posts,
            scripts, captions, and visuals that help your brand stay consistent,
            relevant, and memorable across all platforms.

        </p>

    </div>

</section>

<!-- BENEFITS -->

<section class="benefits">

    <div class="container">

        <h2 class="section-title">

            What You Get

        </h2>

        <div class="benefit-grid">

            <div class="benefit">

                <i class="ti ti-pencil"></i>

                <h3>Blog Writing</h3>

                <p>
                    SEO-optimized blogs that rank and attract organic traffic.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-brand-instagram"></i>

                <h3>Social Media Content</h3>

                <p>
                    Engaging posts, captions and ideas for Instagram & LinkedIn.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-video"></i>

                <h3>Script Writing</h3>

                <p>
                    High-converting scripts for reels, ads and YouTube videos.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-brush"></i>

                <h3>Creative Strategy</h3>

                <p>
                    Unique content ideas aligned with your brand voice.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-search"></i>

                <h3>SEO Content</h3>

                <p>
                    Content optimized to rank higher on Google.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-calendar"></i>

                <h3>Content Planning</h3>

                <p>
                    Monthly content calendars for consistent growth.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- PROCESS -->

<section class="process">

    <div class="container">

        <h2 class="section-title">

            Our Content Creation Process

        </h2>

        <div class="process-grid">

            <div class="step">

                <div class="step-number">1</div>

                <h3>Research</h3>

                <p>
                    Understand your brand, audience and competitors.
                </p>

            </div>

            <div class="step">

                <div class="step-number">2</div>

                <h3>Strategy</h3>

                <p>
                    Build a content plan tailored to your goals.
                </p>

            </div>

            <div class="step">

                <div class="step-number">3</div>

                <h3>Creation</h3>

                <p>
                    Develop high-quality content for all platforms.
                </p>

            </div>

            <div class="step">

                <div class="step-number">4</div>

                <h3>Growth</h3>

                <p>
                    Publish, optimize and improve performance over time.
                </p>

            </div>

        </div>

