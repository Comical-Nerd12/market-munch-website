<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Email Marketing | Market Munch</title>

    <link rel="stylesheet" href="/stylesheets/service-page.css">
    <link rel="stylesheet" href="/stylesheets/responsive.css">

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<%- include("../header") %>
</head>

<body>



<!-- HERO -->

<section class="hero">

    <div class="container">

        <div>

            <p class="section-small">
                EMAIL MARKETING
            </p>

            <h1>
                Reach Inboxes.<br>
                Build Relationships.<br>
                Drive More Sales.
            </h1>

            <p class="hero-text">
                We create strategic email marketing campaigns that nurture
                leads, retain customers, and increase conversions through
                personalized, data-driven communication.
            </p>

            <div class="hero-buttons">

                <a href="https://wa.me/919350223775?text=Hi! I'm interested in your Email Marketing service." class="btn btn-primary">
                    Contact Us
                </a>

            </div>

        </div>

    </div>

</section>

<div class="showcase-image">

        <img src="/images/email.png"
             alt="Market Munch Dashboard">

    </div>

<!-- ABOUT -->

<section class="about-service">

    <div class="container">

        <h2 class="section-title">

            Build Lasting Customer Relationships

        </h2>

        <p class="section-text">

            Email marketing remains one of the highest ROI digital marketing
            channels. We help you connect with your audience through
            personalized campaigns that increase engagement, build trust,
            and turn subscribers into loyal customers.

        </p>

    </div>

</section>

<!-- BENEFITS -->

<section class="benefits">

    <div class="container">

        <h2 class="section-title">

            What You Get

        </h2>

        <div class="benefit-grid">

            <div class="benefit">

                <i class="ti ti-mail"></i>

                <h3>Email Campaigns</h3>

                <p>
                    Professionally designed campaigns tailored to your business goals.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-users-group"></i>

                <h3>Audience Segmentation</h3>

                <p>
                    Send personalized emails to the right audience at the right time.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-automation"></i>

                <h3>Email Automation</h3>

                <p>
                    Automate welcome emails, follow-ups and customer journeys.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-edit"></i>

                <h3>Content & Copywriting</h3>

                <p>
                    Compelling email copy that improves open rates and conversions.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-chart-line"></i>

                <h3>Performance Tracking</h3>

                <p>
                    Monitor opens, clicks, conversions and campaign performance.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-report-analytics"></i>

                <h3>Detailed Reports</h3>

                <p>
                    Transparent reports with insights to continuously improve results.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- PROCESS -->

<section class="process">

    <div class="container">

        <h2 class="section-title">

            Our Email Marketing Process

        </h2>

        <div class="process-grid">

            <div class="step">

                <div class="step-number">1</div>

                <h3>Plan</h3>

                <p>
                    Understand your audience and define campaign objectives.
                </p>

            </div>

            <div class="step">

                <div class="step-number">2</div>

                <h3>Create</h3>

                <p>
                    Design engaging email templates with persuasive content.
                </p>

            </div>

            <div class="step">

                <div class="step-number">3</div>

                <h3>Launch</h3>

                <p>
                    Deliver campaigns at the right time for maximum engagement.
                </p>

            </div>

            <div class="step">

                <div class="step-number">4</div>

                <h3>Optimize</h3>

                <p>
                    Analyze results and refine campaigns for higher conversions.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- CTA -->

<section class="cta">

    <div class="cta-content">

        <h2>
            Ready To Grow With Email Marketing?
        </h2>

        <p>
            Let's create email campaigns that strengthen customer relationships and drive consistent business growth.
        </p>

    </div>

    <div class="cta-buttons">

        <a
        class="btn-secondary"
        href="https://wa.me/919350223775?text=Hi! I'm interested in your Email Marketing service."
        target="_blank">

            Let's Talk

        </a>

    </div>

</section>

<%- include("../footer") %>

