<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>WhatsApp Marketing | Market Munch</title>

    <link rel="stylesheet" href="/stylesheets/service-page.css">
    <link rel="stylesheet" href="/stylesheets/responsive.css">

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

</head>

<body>

<%- include("../header") %>

<!-- HERO -->

<section class="hero">

    <div class="container">

        <div>

            <p class="section-small">
                WHATSAPP MARKETING
            </p>

            <h1>
                Connect Instantly.<br>
                Engage Personally.<br>
                Convert Faster.
            </h1>

            <p class="hero-text">
                Reach your customers where they already spend their time.
                We create personalized WhatsApp marketing campaigns that
                boost engagement, generate leads, and strengthen customer
                relationships at scale.
            </p>

            <div class="hero-buttons">

                <a href="https://wa.me/919350223775?text=Hi! I'm interested in your WhatsApp Marketing service."
                    class="btn btn-primary">
                    Contact Us
                </a>

            </div>

        </div>

    </div>

</section>

<div class="showcase-image">

        <img src="/images/whatsapp.png"
             alt="Market Munch Dashboard">

    </div>

<!-- ABOUT -->

<section class="about-service">

    <div class="container">

        <h2 class="section-title">

            Build Meaningful Customer Conversations

        </h2>

        <p class="section-text">

            WhatsApp is one of the most effective communication channels for
            modern businesses. From promotional campaigns to customer support
            and personalized messaging, we help you engage customers with
            timely, relevant, and high-converting conversations.

        </p>

    </div>

</section>

<!-- BENEFITS -->

<section class="benefits">

    <div class="container">

        <h2 class="section-title">

            What You Get

        </h2>

        <div class="benefit-grid">

            <div class="benefit">

                <i class="ti ti-brand-whatsapp"></i>

                <h3>Broadcast Campaigns</h3>

                <p>
                    Reach hundreds of customers instantly with personalized promotional messages.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-message-circle"></i>

                <h3>Customer Engagement</h3>

                <p>
                    Build stronger relationships through direct and meaningful conversations.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-bell-ringing"></i>

                <h3>Promotions & Updates</h3>

                <p>
                    Share offers, announcements and product updates with high visibility.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-user-check"></i>

                <h3>Lead Nurturing</h3>

                <p>
                    Guide prospects through the buying journey with personalized follow-ups.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-settings"></i>

                <h3>Automated Messaging</h3>

                <p>
                    Set up automated replies, reminders and customer workflows.
                </p>

            </div>

            <div class="benefit">

                <i class="ti ti-report-analytics"></i>

                <h3>Campaign Insights</h3>

                <p>
                    Track campaign performance and continuously improve customer engagement.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- PROCESS -->

<section class="process">

    <div class="container">

        <h2 class="section-title">

            Our WhatsApp Marketing Process

        </h2>

        <div class="process-grid">

            <div class="step">

                <div class="step-number">1</div>

                <h3>Plan</h3>

                <p>
                    Understand your audience and define campaign objectives.
                </p>

            </div>

            <div class="step">

                <div class="step-number">2</div>

                <h3>Create</h3>

                <p>
                    Craft personalized messages and engaging campaign content.
                </p>

            </div>

            <div class="step">

                <div class="step-number">3</div>

                <h3>Launch</h3>

                <p>
                    Deliver campaigns to the right audience at the right time.
                </p>

            </div>

            <div class="step">

                <div class="step-number">4</div>

                <h3>Optimize</h3>

                <p>
                    Monitor engagement, refine messaging and maximize conversions.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- CTA -->

<section class="cta">

    <div class="cta-content">

        <h2>
            Ready To Grow With WhatsApp Marketing?
        </h2>

        <p>
            Let's create personalized WhatsApp campaigns that engage customers, generate leads and grow your business.
        </p>

    </div>

    <div class="cta-buttons">

        <a
            class="btn-secondary"
            href="https://wa.me/919350223775?text=Hi! I'm interested in your WhatsApp Marketing service."
            target="_blank">

            Let's Talk

        </a>

    </div>

</section>

<%- include("../footer") %>

</body>

</html>