                <p>
                    Understand how users interact with your website.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- PROCESS -->

<section class="process">

    <div class="container">

        <h2 class="section-title">

            Our Analytics Process

        </h2>

        <div class="process-grid">

            <div class="step">

                <div class="step-number">1</div>

                <h3>Audit</h3>

                <p>
                    Analyze your current tracking and data setup.
                </p>

            </div>

            <div class="step">

                <div class="step-number">2</div>

                <h3>Setup</h3>

                <p>
                    Implement GA4, events and conversion tracking.
                </p>

            </div>

            <div class="step">

                <div class="step-number">3</div>

                <h3>Monitor</h3>

                <p>
                    Track performance and user behavior continuously.
                </p>

            </div>

            <div class="step">

                <div class="step-number">4</div>

                <h3>Optimize</h3>

                <p>
                    Improve campaigns and UX using data insights.
                </p>

