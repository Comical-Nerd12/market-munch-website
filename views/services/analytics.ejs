        </p>

        <div class="hero-buttons">

            <a href="https://wa.me/919350223775" class="btn btn-primary">
                Free Analytics Audit
            </a>

            <a href="/contact" class="btn btn-secondary">
                Contact Us
            </a>

        </div>

    </div>

</section>

<!-- ABOUT -->

<section class="about-service">

    <div class="container">

        <h2 class="section-title">

            Turn Data Into Business Growth

        </h2>

        <p class="section-text">

            Data is the backbone of modern marketing. Without proper tracking,
