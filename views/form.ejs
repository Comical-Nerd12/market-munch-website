
 <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"
/>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4">
    </script>
    <head><meta name="viewport" content="width=device-width, initial-scale=1.0"></head>
<link rel="stylesheet" href="/stylesheets/form.css">

<div class="form-page">

    <div class="form-heading">

        <h1>Tell us what you need</h1>

        <p>
            Fill out the form below and we'll get back to you within
            <strong>24 hours.</strong>
        </p>

    </div>

    <form id="contactForm" class="contact-form">

        <div class="form-group">

            <label for="name">Full Name</label>

            <input
                id="name"
                type="text"
                name="name"
                placeholder="Your full name"
                required
            >

        </div>

        <div class="form-group">

            <label for="email">Email Address</label>

            <input
                id="email"
                type="email"
                name="email"
                placeholder="you@example.com"
                required
            >

        </div>

       <div class="form-group">

    <label for="phone">WhatsApp Number</label>

    <input
        id="phone"
        type="tel"
        name="phone"
        placeholder="9876543210"
        required
        maxlength="10"
        pattern="[0-9]{10}"
        inputmode="numeric"
        title="Please enter a valid 10-digit mobile number"
        oninput="this.value=this.value.replace(/[^0-9]/g,'')"
    >

</div>

        <div class="form-group">

            <label for="role">I am a...</label>

            <select
                id="role"
                name="role"
                required
            >

                <option value="">Select your category</option>

                <option value="Freelancer">Freelancer</option>

                <option value="Creator">Creator</option>

                <option value="Startup">Startup</option>

            </select>

        </div>

        <div class="form-group">

            <label for="document">Document Required</label>

            <input
                id="document"
                type="text"
                name="document"
                placeholder="Example: NDA, Service Agreement..."
            >

        </div>

        <div class="form-group">

            <label for="message">Tell us about your requirement</label>

            <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Briefly describe your legal requirement..."
                required
            ></textarea>

        </div>

        <button
            type="submit"
            class="submit-btn"
        >
            Send my brief
        </button>

    </form>

    <!-- Success / Error Message -->

    <div
        id="formStatus"
        class="form-status"
    ></div>

    <p class="privacy-note">
        By submitting this form, you agree that LegalLift may contact you
        regarding your enquiry through email or WhatsApp.
    </p>

</div>

<script src="/javascripts/form.js"></script>

