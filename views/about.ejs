<div class="about-page">

    <!-- Hero -->

    <section class="about-hero">

        <h1>About IfThisGoesWrong</h1>

        <div class="founder-photo">

            <img
                src="/images/kashish.png"
                alt="Kashish - Founder of LegalLift"
            >

        </div>

        <h2>Kashish</h2>

        <p class="subtitle">
            Founder • Advocate
        </p>

    </section>

    <!-- Story -->

    <section class="about-card">

        <h3>Why IfThisGoesWrong?</h3>

        <p>

           IfThisGoesWrong was created to make quality legal documentation
            simple, affordable and accessible for freelancers,
            startups and creators.

            Instead of relying on generic online templates,
            every document is carefully drafted according
            to your actual requirements.

            Whether you're protecting your business,
            signing your first client,
            or sending a legal notice,
            our goal is to make legal paperwork easy to understand
            and stress-free.

        </p>

    </section>

    <!-- Mission -->

    <section class="about-card">

        <h3>Our Mission</h3>

        <p>

            To provide professional legal drafting
            that is transparent, affordable and
            accessible for everyone building
            something of their own.

        </p>

    </section>

    <!-- Disclaimer -->

    <section class="disclaimer">

        <strong>Disclaimer</strong>

        <p>

            IfThisGoesWrong provides legal document drafting
            and documentation assistance.

            It does not constitute legal representation
            or legal advice from a licensed advocate.

        </p>

    </section>

